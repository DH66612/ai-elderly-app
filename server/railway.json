{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "pkgs": [
        "ffmpeg",
        "python312",
        "python312Packages.pip",
        "expat",
        "zlib",
        "libGL",
        "libGLU",
        "libEGL",
        "libGLESv2"
      ]
    }
  },
  "deploy": {
    "startCommand": "pip install flask flask-cors opencv-python-headless mediapipe && npm run build && NODE_ENV=production node dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
