# ==================== API 配置 ====================
# 真机调试必填！请填写你的电脑局域网IP

# 查看方法：
# Mac/Linux: 终端执行 ifconfig | grep "inet " | grep -v 127.0.0.1
# Windows: 命令行执行 ipconfig，找到 IPv4 地址

# 局域网IP示例（替换为你自己的IP）:
EXPO_PUBLIC_LOCAL_IP=192.168.1.100

# ==================== 生产环境配置 ====================
# 如果部署到服务器，填写完整的后端地址：
# EXPO_PUBLIC_BACKEND_BASE_URL=https://api.example.com
